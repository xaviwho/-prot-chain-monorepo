# PureProtX Environment Configuration
# Copy this file to .env: cp .env.example .env
#
# A pre-funded test wallet is provided below for immediate reproducibility.
# PureChain is a zero-gas-fee PoA network -- no cryptocurrency purchase needed.
#
# To generate your own wallet instead:
#   python -c "from web3 import Web3; a=Web3().eth.account.create(); print(f'Key: {a.key.hex()[2:]}\nAddr: {a.address}')"

# PureChain Private Key (64 hex chars, no 0x prefix)
# Test wallet -- replace with your own for production use
TEST_PRIVATE_KEY=3b0dd1bc2a91bdcc36d92dfcfc99e5791571d306171f52c4a6e4c849b4333013

# PureChain RPC endpoint
PURECHAIN_RPC_URL=https://purechainnode.com:8547

# Deployed contract address
CONTRACT_ADDRESS=0xb8eb74663c1297825b188D8454a469d02Cc7d56C

# Network configuration
NETWORK=mainnet
